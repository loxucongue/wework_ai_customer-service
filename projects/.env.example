CHAT_BACKEND=ai_paths
AI_PATHS_API_BASE=http://127.0.0.1:8000
AI_PATHS_API_KEY=

# Optional. When set, POST /api/ai/chat requires:
# Authorization: Bearer <AI_EXTERNAL_API_KEY>
AI_EXTERNAL_API_KEY=

# Required for image upload in the local chat test UI.
COZE_BUCKET_ENDPOINT_URL=
COZE_BUCKET_NAME=

# Set CHAT_BACKEND=coze to call the legacy Coze main workflow directly.
COZE_WORKLOAD_API_TOKEN=
COZE_API_BASE_URL=https://api.coze.cn
COZE_EXTRA_HEADERS=
